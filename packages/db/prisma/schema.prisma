// remote-work-radar — Prisma schema
// Every model here has a specific reason. See CLAUDE.md for do/don't rules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Source — one row per job board we scrape.
// -----------------------------------------------------------------------------

model Source {
  id           String    @id @default(cuid())
  slug         String    @unique
  displayName  String
  homepageUrl  String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  jobRefs      JobSourceRef[]

  @@map("sources")
}

// -----------------------------------------------------------------------------
// Company — deduped by lowercased name.
// -----------------------------------------------------------------------------

model Company {
  id             String   @id @default(cuid())
  name           String   @unique
  nameNormalized String   @unique
  homepageUrl    String?
  logoUrl        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs           Job[]

  @@map("companies")
}

// -----------------------------------------------------------------------------
// Skill — tag entity. Free-form ingest, normalized display.
// -----------------------------------------------------------------------------

model Skill {
  id          String    @id @default(cuid())
  slug        String    @unique
  displayName String
  jobs        JobSkill[]

  @@map("skills")
}

// -----------------------------------------------------------------------------
// Job — the core entity.
// -----------------------------------------------------------------------------

model Job {
  id                String     @id @default(cuid())

  // Identity + dedup
  dedupKey          String     @unique
  titleOriginal     String
  titleNormalized   String
  descriptionMd     String     @db.Text
  applyUrl          String

  // Company link
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id])

  // Geo / timezone gates
  isUsOnly          Boolean    @default(false)
  isRemoteAnywhere  Boolean    @default(false)
  allowedRegions    String[]   @default([])
  timezoneMinUtcOffset Int?
  timezoneMaxUtcOffset Int?

  // Compensation
  hourlyMinUsd      Decimal?   @db.Decimal(10, 2)
  hourlyMaxUsd      Decimal?   @db.Decimal(10, 2)
  salaryMinUsd      Decimal?   @db.Decimal(12, 2)
  salaryMaxUsd      Decimal?   @db.Decimal(12, 2)
  paymentTypes      PaymentType[]  @default([])
  contractTypes     ContractType[] @default([])

  // Beginner signals
  isEntryLevel      Boolean    @default(false)
  requiredExperienceYears Int?
  paymentMethodsHint PaymentMethodHint[] @default([])

  // Trust signals
  isScamSuspected   Boolean    @default(false)
  scamReasons       String[]   @default([])

  // Skills + sources
  skills            JobSkill[]
  sourceRefs        JobSourceRef[]

  // Lifecycle
  postedAt          DateTime?
  firstSeenAt       DateTime   @default(now())
  lastSeenAt        DateTime   @default(now())
  isActive          Boolean    @default(true)

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([isActive, isUsOnly, isEntryLevel])
  @@index([postedAt(sort: Desc)])
  @@index([companyId])
  @@map("jobs")
}

enum PaymentType {
  HOURLY
  RETAINER
  FIXED
  SALARIED
  EQUITY_ONLY
  UNPAID
}

enum ContractType {
  CONTRACT
  PART_TIME
  FULL_TIME
  INTERNSHIP
  FREELANCE
}

enum PaymentMethodHint {
  BANK_TRANSFER
  WISE
  PAYONEER
  CRYPTO
  PAYPAL
  DEEL
  UNKNOWN
}

// -----------------------------------------------------------------------------
// JobSourceRef — where we saw this job. One job can appear on many sources.
// -----------------------------------------------------------------------------

model JobSourceRef {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceId     String
  source       Source   @relation(fields: [sourceId], references: [id])

  externalId   String
  sourceUrl    String
  rawSnapshot  Json
  fetchedAt    DateTime @default(now())

  @@unique([sourceId, externalId])
  @@index([jobId])
  @@map("job_source_refs")
}

// -----------------------------------------------------------------------------
// JobSkill — plain many-to-many join.
// -----------------------------------------------------------------------------

model JobSkill {
  jobId     String
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill  @relation(fields: [skillId], references: [id])

  @@id([jobId, skillId])
  @@map("job_skills")
}

# --- Database ---
# Neon free tier: paste connection string from console.neon.tech
# Supabase free tier: Settings → Database → Connection string
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- ETL ---
# Rate limits (requests per minute per source)
ETL_RATE_LIMIT_RPM=30

# HN Who's Hiring — leave empty to auto-detect current month
HN_HIRING_THREAD_ID=""

# --- Auth.js v5 ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# GitHub OAuth app — https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github  (and your prod URL when you deploy)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- MCP ---
# The MCP server reads the same DATABASE_URL. Nothing else needed.

# --- Database ---
# Local Docker: use the docker-compose default
# Neon free tier: paste connection string from console.neon.tech
# Supabase free tier: Settings → Database → Connection string
DATABASE_URL="postgresql://rwr:rwr@localhost:5432/rwr?schema=public"

# --- ETL ---
# Where to store raw scrape snapshots (JSONB in DB is default, this is optional file backup)
ETL_SNAPSHOT_DIR="./services/etl/data/snapshots"

# Rate limits (requests per minute per source)
ETL_RATE_LIMIT_RPM=30

# HN Who's Hiring — leave empty to auto-detect current month
HN_HIRING_THREAD_ID=""

# --- Next.js / Auth ---
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (for login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (magic link)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@localhost"

# --- MCP ---
# The MCP server reads the same DATABASE_URL. Nothing else needed.
